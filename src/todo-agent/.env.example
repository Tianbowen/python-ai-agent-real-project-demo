# .env.example  ← 配置模板，复制为 .env 后填写真实值

LLM_API_BASE    = http://your-llm-server-ip:port/v1
LLM_API_KEY     = your-api-key
LLM_MODEL_NAME  = your-model-name
LLM_TEMPERATURE = 0.7
LLM_MAX_TOKENS  = 2048

API_HOST        = 0.0.0.0
API_PORT        = 18861
MAX_CONCURRENCY = 20

SESSION_TTL_S   = 1800
SESSION_MAXSIZE = 10000
TASKS_YAML_PATH = tasks.yaml
HISTORY_MAX     = 20